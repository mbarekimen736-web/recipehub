{% extends 'base.html.twig' %}

{% block title %}{{ recette.titre }}{% endblock %}

{% block body %}
    <h1>{{ recette.titre }}</h1>

    <div class="row">
        <div class="col-4">
            <h3>Ingrédients</h3>
            <ul>
                {% for ing in recette.ingredients %}
                    <li>{{ ing.quantite }} - {{ ing.nom }}</li>
                {% else %}
                    <li>Aucun ingrédient.</li>
                {% endfor %}
            </ul>
        </div>
        <div class="col-8">
            <h3>Instructions</h3>
            <p>{{ recette.instructions|nl2br }}</p>
        </div>
    </div>

    <p><a href="{{ path('recette_edit', {id: recette.id}) }}">Modifier</a></p>

    <form method="post" action="{{ path('recette_delete', {id: recette.id}) }}" onsubmit="return confirm('Supprimer cette recette ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recette.id) }}">
        <button type="submit">Supprimer</button>
    </form>
{% endblock %}
